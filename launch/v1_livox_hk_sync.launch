<launch>
	<arg name="rviz" default="true" />
    <param name="use_sim_time" value="true" />
	<rosparam command="load" file="$(find fast_livo)/config/v1_livox_hk_sync.yaml" />

	<!--   launch-prefix="xterm -e gdb -ex run -args"   -->
	<node pkg="fast_livo" type="fastlivo_mapping" name="laserMapping" output="screen"  required="false"> 
		<!-- <rosparam file="/home/liunao/csg/slam/navs/param/camera_v1_livox_hk_sync.yaml" /> -->
		<rosparam file="$(find fast_livo)/config/camera_v1_livox_hk_sync.yaml" />
	</node>
	
	<group if="$(arg rviz)">
		<node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz_fast_livo" args="-d $(find fast_livo)/rviz_cfg/loam_livox_ouster.rviz" />
	</group>

    <!-- <node pkg="fast_livo" type="save_registered_cloud" name="save_registered_cloud" args="/cloud_registered:=/map_update_data  5" output="screen"/> -->
    <!-- <node pkg="fast_livo" type="livox_to_pointcloud2" name="livox_to_pointcloud2"   output="screen"/> -->



	<node pkg="rosbag" type="play" name="playrosbag" output="screen" required="false" args="/home/bag/sync/v1_horizonal_hk/sync_V1_livox_hk_E_east.bag /image:=/hk_camera/image_color -d 1 -s 5 -r 0.5 --clock --duration 210 "/> 



</launch>
